# Copy to .env and replace placeholders with real values.
# cp .env.sample .env

# GCP — entire service account key JSON as one line (same content as the *.json from Google Cloud).
# One-line locally:  GOOGLE_SERVICE_ACCOUNT_JSON=$(jq -c . path/to/key.json)
# In Node:  credentials: JSON.parse(process.env.GOOGLE_SERVICE_ACCOUNT_JSON)
GOOGLE_SERVICE_ACCOUNT_JSON=

GOOGLE_CLOUD_PROJECT=your_gcp_project_id

# BigQuery export dataset is usually analytics_<this>.
GA4_PROPERTY_ID=your_ga4_property_id

# Snowflake — service user + key pair only (no password in this PoC)
# SNOWFLAKE_ACCOUNT: org-account form, e.g. myorg-myaccount
SNOWFLAKE_ACCOUNT=your_account
SNOWFLAKE_USER=your_user

# PKCS#8 PEM private key (.pub is registered on the Snowflake user; client uses .p8 only)
# Typical: ./.secrets/snowflake_rsa_key.p8 (entire .secrets/ dir gitignored)
SNOWFLAKE_PRIVATE_KEY_PATH=
# Or one line with literal \n for newlines:
# SNOWFLAKE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# SNOWFLAKE_PRIVATE_KEY_PASS=

# Optional defaults for sessions / loads
# SNOWFLAKE_ROLE=
SNOWFLAKE_WAREHOUSE=your_warehouse
SNOWFLAKE_DATABASE=your_database
SNOWFLAKE_SCHEMA=your_schema
